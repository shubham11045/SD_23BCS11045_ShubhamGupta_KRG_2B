        <mxCell id="hRqnKYPNeOlWcXI3mcQv-1" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="Designing e-commerce applictaion with following requirements:&lt;div&gt;1. User login service&lt;/div&gt;&lt;div&gt;2. product catalog service&lt;/div&gt;&lt;div&gt;3.cart service&lt;br&gt;4. order status service&lt;br&gt;5. Search service&lt;/div&gt;&lt;div&gt;6. check out service.&lt;br&gt;Optimize the product serch service and inventory stock management system.&lt;/div&gt;" vertex="1">
          <mxGeometry height="110" width="520" x="30" y="40" as="geometry" />
        </mxCell>
        <mxCell id="hRqnKYPNeOlWcXI3mcQv-3" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="Functional Requirements:&lt;br&gt;1. user login&lt;br&gt;2. product&amp;nbsp; serach service&lt;br&gt;3. user cart service&lt;br&gt;4. User Order service&lt;br&gt;5. User Checkout service&lt;div&gt;6. User order status check service.&lt;br&gt;7. Admin stock management service&lt;/div&gt;" vertex="1">
          <mxGeometry height="150" width="170" x="20" y="170" as="geometry" />
        </mxCell>
        <mxCell id="hRqnKYPNeOlWcXI3mcQv-4" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="Non Functinal Requiremnt:&lt;div&gt;1. High availabilty&lt;br&gt;2. low latency in fetching products.&lt;br&gt;3. Annual downtime &amp;lt;9 hours.&lt;br&gt;4. Real time update of products&lt;br&gt;5. secure tranaction system.&amp;nbsp;&lt;/div&gt;" vertex="1">
          <mxGeometry height="120" width="220" x="215" y="170" as="geometry" />
        </mxCell>
